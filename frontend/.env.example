# Copy to .env.local and adjust. Never commit .env.local.
#
# Everything Vite exposes to the browser must be prefixed VITE_ — and anything
# with that prefix IS PUBLIC, baked into the JS bundle. Never put a secret,
# an API key, or a database URL in this file.

# Base URL for the API. Left as /api, the Vite dev proxy forwards to the
# Express server (see vite.config.ts).
VITE_API_URL=/api

# Where the dev proxy points. Match your backend's port.
VITE_API_PROXY=http://localhost:4000

# Money and date formatting.
VITE_CURRENCY=LKR
VITE_LOCALE=en-LK
