{
  "name": "tims-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TIMS API — Express + PostgreSQL",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "migrate": "node --experimental-strip-types src/db/migrate.ts up",
    "migrate:down": "node --experimental-strip-types src/db/migrate.ts down",
    "seed": "node --experimental-strip-types src/db/seed.ts",
    "test": "node --test"
  }
}
