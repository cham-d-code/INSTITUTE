# Copy to .env and fill in. NEVER commit .env — it holds real secrets.

NODE_ENV=development
PORT=4000

# The browser origin allowed to call this API with credentials. Must be an
# explicit origin, not "*" — the refresh cookie requires it.
CORS_ORIGIN=http://localhost:5173

# --- PostgreSQL -------------------------------------------------------------
DATABASE_URL=postgresql://tims:change-me@localhost:5432/tims

# The application role must NOT hold UPDATE or DELETE on the audit tables
# (NFR-10). Grant it a separate, append-only role and use it here.
DATABASE_POOL_MAX=10

# --- Auth -------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# FR-003: configurable idle timeout.
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
IDLE_TIMEOUT_MINUTES=30

# Cost factor for password hashing. 12 is a sane floor.
BCRYPT_ROUNDS=12

# --- QR tokens (FR-041) -----------------------------------------------------
# Pepper mixed into student QR tokens. Rotating this invalidates every printed
# card, so treat it as permanent once cards are in circulation.
QR_TOKEN_SECRET=

# --- Uploads ----------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=5242880

# --- Backups (NFR-06) -------------------------------------------------------
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
